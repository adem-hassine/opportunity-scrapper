APP_NAME=OpenClaw
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://${POSTGRES_USER:-openclaw}:${POSTGRES_PASSWORD:-openclaw}@localhost:${POSTGRES_PORT:-5432}/${POSTGRES_DB:-openclaw}

# Postgres (optional — defaults shown below)
POSTGRES_DB=openclaw
POSTGRES_USER=openclaw
POSTGRES_PASSWORD=replace-me
POSTGRES_PORT=5432

# AI — OpenAI-compatible API (works with OpenAI, DeepSeek, Google Gemini, etc.)
# Option A: Google Gemini (free, get key at aistudio.google.com)
#OPENAI_API_KEY=replace-me
#OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#OPENAI_MODEL=gemini-2.0-flash
# Option B: DeepSeek (very cheap, get key at platform.deepseek.com)
#OPENAI_API_KEY=sk-1ac0a6c1352a4ae28879ca6bb736291e
#OPENAI_BASE_URL=https://api.deepseek.com
#OPENAI_MODEL=deepseek-chat
# Option C: OpenAI (paid)
# OPENAI_API_KEY=sk-proj-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDINGS_MODEL=text-embedding-004

TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_CHAT_ID=replace-me
TELEGRAM_ALLOWED_USER_IDS=

MONITOR_INTERVAL_SECONDS=900
JOB_CRITERIA_FILE=config/job_criteria.yml

RESUME_DIR=data/resumes
PROPOSAL_EXAMPLES_DIR=data/proposal_examples
PLAYWRIGHT_STORAGE_DIR=data/playwright
