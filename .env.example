APP_NAME=OpenClaw
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://openclaw:openclaw@localhost:5432/openclaw

OPENAI_API_KEY=replace-me
OPENAI_MODEL=replace-me
OPENAI_EMBEDDINGS_MODEL=replace-me

TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_CHAT_ID=replace-me
TELEGRAM_ALLOWED_USER_IDS=

MONITOR_INTERVAL_SECONDS=900
PLATFORM_TARGETS=free-work,malt,lehibou

MINIMUM_TJM=650
REMOTE_REQUIRED=true
EXCLUDED_KEYWORDS=wordpress,php,onsite only
REQUIRED_KEYWORDS=java,spring,sso,keycloak
AUTO_REJECT_SCORE_BELOW=45
ALERT_SCORE_FROM=75

RESUME_DIR=data/resumes
PROPOSAL_EXAMPLES_DIR=data/proposal_examples
PLAYWRIGHT_STORAGE_DIR=data/playwright

